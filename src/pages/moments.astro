---
import { getCollection, render } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const authorName = "见祈"; // 想改昵称就改这里

const moments = await getCollection("moments");
moments.sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const renderedMoments = await Promise.all(
	moments.map(async (moment) => {
		const { Content } = await render(moment);
		return {
			...moment,
			Content,
		};
	}),
);

const formatMomentTime = (date: Date) =>
	new Intl.DateTimeFormat("zh-CN", {
		month: "numeric",
		day: "numeric",
		hour: "2-digit",
		minute: "2-digit",
		hour12: false,
	}).format(date);

const formatFullTime = (date: Date) =>
	new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		hour: "2-digit",
		minute: "2-digit",
		hour12: false,
	}).format(date);
---

<MainGridLayout title="动态 | Syki" description="像朋友圈一样记录碎碎念与灵感">
  <div class="moments-page card-base">
    <div class="page-header">
      <h1 class="moments-title">relics</h1>
      <p class="moments-subtitle">把今天认真地留给未来的自己。</p>
    </div>

    {
      renderedMoments.length === 0 ? (
        <p class="empty-state">宇宙寂寥，目前还没有捕捉到任何信号。</p>
      ) : (
        <div class="timeline">
          {renderedMoments.map((moment) => (
            <article class="timeline-item">
              <div class="timeline-left">
                <div class="avatar">{authorName.slice(0, 1)}</div>
                <div class="timeline-line"></div>
              </div>

              <div class="timeline-right">
                <div class="moment-meta">
                  <span class="moment-author">{authorName}</span>
                  <time
                    class="moment-time"
                    datetime={moment.data.published.toISOString()}
                    title={formatFullTime(moment.data.published)}
                  >
                    {formatMomentTime(moment.data.published)}
                  </time>
                </div>

                <div class="moment-card">
                  <div class="moment-body">
                    <moment.Content />
                  </div>

                  <div class="moment-footer">
                    <span>♡ 留住这一刻</span>
                    <span class="dot">·</span>
                    <span>🫧 moment</span>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }
  </div>
</MainGridLayout>

<style>
  .moments-page {
    position: relative;
    z-index: 10;
    width: 100%;
    padding: 1.6rem 2rem 2rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
  }

  .moments-title {
    margin: 0;
    font-size: 2.3rem;
    line-height: 1.15;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: 0.02em;
  }

  .moments-subtitle {
    margin: 0.55rem 0 0;
    font-size: 0.98rem;
    color: var(--text-muted);
    opacity: 0.9;
  }

  .empty-state {
    margin: 0;
    line-height: 1.9;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
  }

  .timeline-left {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100%;
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 1rem;
    font-weight: 700;
    color: white;
    background: linear-gradient(135deg, #9b8cff, #c7bfff);
    box-shadow: 0 8px 18px rgba(155, 140, 255, 0.28);
    flex-shrink: 0;
  }

  .timeline-line {
    width: 2px;
    flex: 1;
    margin-top: 0.55rem;
    background: linear-gradient(
      to bottom,
      rgba(155, 140, 255, 0.45),
      rgba(155, 140, 255, 0.08)
    );
    border-radius: 999px;
    min-height: 48px;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  .timeline-right {
    min-width: 0;
  }

  .moment-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
    padding-top: 0.15rem;
  }

  .moment-author {
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary);
  }

  .moment-time {
    font-size: 0.88rem;
    color: var(--text-muted);
    opacity: 0.95;
  }

  .moment-card {
    background: rgba(255, 255, 255, 0.6);
    border-radius: 22px;
    padding: 1rem 1.15rem 0.85rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(8px);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .moment-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.08);
  }

  .moment-body :global(p) {
    margin: 0 0 0.95rem;
    line-height: 1.95;
    word-break: break-word;
  }

  .moment-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .moment-body :global(img) {
    display: block;
    width: min(460px, 100%);
    max-width: 100%;
    height: auto;
    margin-top: 0.8rem;
    border-radius: 16px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  }

  .moment-body :global(a) {
    word-break: break-all;
  }

  .moment-body :global(blockquote) {
    margin: 0.8rem 0;
    padding: 0.8rem 1rem;
    border-left: 4px solid rgba(155, 140, 255, 0.6);
    background: rgba(155, 140, 255, 0.08);
    border-radius: 12px;
  }

  .moment-body :global(ul),
  .moment-body :global(ol) {
    padding-left: 1.3rem;
    margin: 0.7rem 0 1rem;
    line-height: 1.9;
  }

  .moment-footer {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.9rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 0.84rem;
    color: var(--text-muted);
    opacity: 0.9;
  }

  .dot {
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .moments-page {
      padding: 1.1rem 1rem 1.4rem;
    }

    .moments-title {
      font-size: 1.9rem;
    }

    .timeline-item {
      grid-template-columns: 46px minmax(0, 1fr);
      gap: 0.75rem;
    }

    .avatar {
      width: 36px;
      height: 36px;
      font-size: 0.9rem;
    }

    .moment-card {
      border-radius: 18px;
      padding: 0.9rem 0.95rem 0.8rem;
    }

    .moment-meta {
      flex-wrap: wrap;
      gap: 0.45rem 0.7rem;
    }
  }
</style>